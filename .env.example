# Postgres connection (Drizzle + node-postgres). Many routes and `next build` sitemap use it — must be reachable at build.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Schema changes: `npx drizzle-kit generate` → review `drizzle/migrations` → `npx drizzle-kit migrate` (or `drizzle-kit push` in dev only)

# Zarinpal (customer checkout) — sandbox: https://sandbox.zarinpal.com
ZARINPAL_MERCHANT_ID=
# 1 or true for sandbox
ZARINPAL_SANDBOX=1
ANTHROPIC_API_KEY=sk-ant-api03-...
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
# Public site origin — full URL preferred (https://...). Bare hostnames (e.g. example.ir) get https:// added automatically where this app parses URLs.
NEXT_PUBLIC_SITE_URL=https://your-domain.ir
NEXT_PUBLIC_WHATSAPP=989123456789
NEXT_PUBLIC_PHONE=02112345678
